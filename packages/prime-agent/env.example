# ─── Talos Web API ──────────────────────────────────────────
TALOS_API_URL=https://talos.0g.ai
TALOS_API_KEY=tak_...           # returned by POST /api/talos (Genesis)
TALOS_ID=                       # optional — auto-resolved from API key

# Multi-agent mode (comma-separated keys)
# TALOS_API_KEYS=tak_aaa,tak_bbb,tak_ccc

# ─── 0G Compute (Decentralised AI Inference) ────────────────
# Priority 1: 0G Compute — verifiable on-chain AI inference
# Get API key at: https://compute.0g.ai
OG_COMPUTE_API_KEY=             # set this to use 0G Compute
OG_COMPUTE_MODEL=qwen3-235b-a22b  # or: GLM-4-9B-Chat, Qwen2.5-72B-Instruct
OG_COMPUTE_API=https://api.0g.ai

# ─── Groq (Fallback LLM — free tier) ───────────────────────
# Used when OG_COMPUTE_API_KEY is not set
# Get free key at: https://console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ─── OpenAI (Last-resort fallback) ─────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ─── 0G Storage (Persistent Agent Memory) ──────────────────
# State checkpoints written automatically after each agent cycle
OG_STORAGE_RPC=https://indexer-storage-testnet-standard.0g.ai
OG_OPERATOR_PRIVATE_KEY=0x...   # EVM private key for 0G Storage signing

# ─── Gensyn AXL (P2P Agent Communication) ──────────────────
# Set AXL_ENABLED=true to activate agent-to-agent mesh networking
# Install AXL binary: https://github.com/gensyn-ai/axl/releases
AXL_ENABLED=true
AXL_PORT=9002
AXL_BINARY=axl                  # path to axl binary if not on PATH

# ─── X (Twitter) Automation ─────────────────────────────────
X_USERNAME=
X_PASSWORD=
X_EMAIL=

# ─── Agent Behaviour ────────────────────────────────────────
AGENT_CYCLE_INTERVAL=30         # seconds between cycles
MAX_ITERATIONS=20               # max tool calls per cycle
BROWSER_HEADLESS=false          # set true for Railway / headless deploy
