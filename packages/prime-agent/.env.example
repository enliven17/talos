# ─── Talos Web API ────────────────────────────────────────
# TALOS_API_KEY is issued at Talos Genesis (displayed once on Launchpad).
# TALOS_ID is resolved automatically from the API key if left blank.

TALOS_API_URL=https://talos.0g.ai

# Single agent:
TALOS_API_KEY=tak_...
TALOS_ID=

# Multi-agent (6 agents in one container — comma-separated, no spaces):
# TALOS_API_KEYS=tak_aaa,tak_bbb,tak_ccc,tak_ddd,tak_eee,tak_fff

# ─── LLM — 0G Compute (recommended — decentralized AI inference) ────
# Get your key at: https://build.0g.ai
OG_COMPUTE_API_KEY=
OG_COMPUTE_MODEL=qwen3-235b-a22b

# ─── LLM — Groq (fallback — free) ────────────────────────
# Get a free key at console.groq.com
GROQ_API_KEY=gsk_...

# ─── LLM — OpenAI (last fallback) ────────────────────────
OPENAI_API_KEY=sk-proj-...

# ─── 0G Operator Wallet ───────────────────────────────────
# EVM private key (0x-prefixed) for 0G Chain transactions
OG_OPERATOR_PRIVATE_KEY=0x...
OG_STORAGE_RPC=https://indexer-storage-testnet-standard.0g.ai

# ─── Gensyn AXL — P2P Agent Communication ─────────────────
# Download AXL binary from https://github.com/gensyn-ai/axl
# Set AXL_ENABLED=true to enable P2P agent-to-agent communication
AXL_ENABLED=false
AXL_PORT=9002
AXL_BINARY=axl

# ─── X (Twitter) Credentials ────────────────────────────
X_USERNAME=
X_PASSWORD=
X_EMAIL=                          # used if X asks for email verification

# ─── Agent Behaviour ──────────────────────────────────────
# AGENT_CYCLE_INTERVAL=300         # seconds between GTM cycles (default 30)
# POLLING_INTERVAL=10              # seconds between API polls (default 10)
# APPROVAL_THRESHOLD=10            # A0GI threshold for auto-approval (default 10)

# ─── Browser (Railway / server) ───────────────────────────
# Set to true when running on Railway or any headless server.
BROWSER_HEADLESS=true
