# ─── Database (Supabase) ──────────────────────────────────
DATABASE_URL=postgresql://postgres.XXXX:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.XXXX:PASSWORD@db.XXXX.supabase.co:5432/postgres

NEXT_PUBLIC_SUPABASE_PROJECT_ID=your_project_ref
NEXT_PUBLIC_SUPABASE_URL=https://your_project_ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...
SUPABASE_SERVICE_ROLE_KEY=

# ─── 0G Chain (Galileo Testnet) ───────────────────────────
# EVM-compatible chain — ChainID 16601
# RPC: https://evmrpc-testnet.0g.ai
# Explorer: https://chainscan-galileo.0g.ai
OG_CHAIN_ID=16601
OG_RPC_URL=https://evmrpc-testnet.0g.ai
NEXT_PUBLIC_OG_CHAIN_ID=16601
NEXT_PUBLIC_OG_RPC_URL=https://evmrpc-testnet.0g.ai

# ─── 0G Operator (Server-side signing) ────────────────────
# EVM private key (0x-prefixed hex) for server-side contract deployment + revenue distribution
OG_OPERATOR_PRIVATE_KEY=0x...
OG_OPERATOR_ADDRESS=0x...

# ─── 0G EVM Contracts (TalosRegistry + TalosNameService) ──
# Run: cd contracts/evm && npx hardhat run scripts/deploy.js --network og_galileo
NEXT_PUBLIC_TALOS_REGISTRY_CONTRACT=0x...
NEXT_PUBLIC_TALOS_NAME_SERVICE_CONTRACT=0x...

# ─── 0G Storage ───────────────────────────────────────────
# https://docs.0g.ai/build-with-0g/storage-sdk
OG_STORAGE_RPC=https://indexer-storage-testnet-standard.0g.ai
OG_STORAGE_NODE=https://rpc-storage-testnet.0g.ai

# ─── 0G Compute ───────────────────────────────────────────
# https://docs.0g.ai/build-with-0g/compute-network
OG_COMPUTE_API=https://api.0g.ai
OG_COMPUTE_API_KEY=

# ─── ENS (Ethereum Name Service) ──────────────────────────
# Agent identity: {agentName}.talos.eth
# Network: sepolia (testnet) or mainnet
ENS_NETWORK=sepolia
ENS_PARENT_DOMAIN=talos.eth
# Private key of talos.eth owner (Ethereum Sepolia) for subname registration
ENS_REGISTRAR_PRIVATE_KEY=0x...
# Ethereum RPC (for ENS operations — separate from 0G Chain)
ETH_SEPOLIA_RPC=https://sepolia.infura.io/v3/YOUR_KEY
ETH_MAINNET_RPC=https://eth.llamarpc.com

# ─── AI Services ──────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
TAVILY_API_KEY=tvly-...

# ─── Talos Genesis ────────────────────────────────────────
# A0GI amount required for TALOS creation (covers gas + on-chain registration)
NEXT_PUBLIC_TALOS_CREATION_COST=0.001

# ─── Gensyn AXL — P2P Agent Mesh ─────────────────────────
# When the web server co-locates with an AXL node (dev / self-hosted),
# set AXL_NODE_URL to expose mesh status via /api/axl/* routes.
# Leave blank if running on Vercel (agents expose AXL separately on Railway).
AXL_NODE_URL=http://127.0.0.1:9002

# ─── Agent Secrets (one per deployed TALOS, set on server) ────────────────────
# Format: TALOS_AGENT_SECRET_{TALOS_CUID} = EVM private key (0x-prefixed)
# Example:
# TALOS_AGENT_SECRET_abc123=0x4c0883a69102937d6231471b5d...
